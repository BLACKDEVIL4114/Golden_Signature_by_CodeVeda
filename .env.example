# .env.example — Copy this to .env and fill in your values
# WARNING: Never commit the actual .env file to source control!

# ─── Authentication ───────────────────────────────────────────────────────────
# Enable login screen (set to true in production!)
AUTH_ENABLED=true

# Users format: username:password:Role (comma-separated for multiple users)
# Roles: Operator, Manager, Executive
AUTH_USERS=youroperator:StrongPass456!:Operator,yourmanager:StrongPass789!:Manager

# Brute-force lockout (SECURITY FIX 7)
# Number of failed attempts before lockout
MAX_LOGIN_ATTEMPTS=5
# Lockout duration in seconds (default: 900 = 15 minutes)
LOGIN_LOCKOUT_SECONDS=900
# Session auto-expiry in seconds (default: 28800 = 8 hours)
SESSION_TIMEOUT_SECONDS=28800

# ─── API Authentication ───────────────────────────────────────────────────────
# Set a strong random API key for the FastAPI backend. Leave empty to disable.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AGPO_API_KEY=replace-with-strong-random-key

# ─── CORS (SECURITY FIX 1) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all (no credentials).
# Example: AGPO_CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
AGPO_CORS_ORIGINS=

# ─── Feature Store Cache Integrity ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FEATURE_STORE_HMAC_SECRET=replace-with-64-char-random-hex-string

# ─── Upload Limits (SECURITY FIX 6) ──────────────────────────────────────────
# Max upload size in bytes (default: 50MB = 52428800)
MAX_UPLOAD_BYTES=52428800

# ─── Data Files (optional overrides) ─────────────────────────────────────────
# PRODUCTION_DATA_FILE=_h_batch_production_data.xlsx
# PROCESS_DATA_FILE=_h_batch_process_data_copy.xlsx
# GOLDEN_SIGNATURE_FILE=artifacts/golden_signatures.json

# ─── Security Logging ─────────────────────────────────────────────────────────
# SECURITY_LOG_FILE=artifacts/security_events.log
